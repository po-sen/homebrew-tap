#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"

require_relative "../lib/version_tracker"

options = {
  all:   false,
  limit: 10,
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: script/tracked-versions [options] [package ...]"

  opts.on("--all", "Print every matching upstream version") do
    options[:all] = true
  end

  opts.on("--limit N", Integer, "Number of recent versions to print per package") do |value|
    options[:limit] = value
  end
end

parser.parse!

packages = VersionTracker.packages
selected_packages = VersionTracker.resolve_package_names(ARGV)

selected_packages.each_with_index do |package_name, index|
  package = packages.fetch(package_name)
  upstream = package.fetch("upstream")
  formulae = package.fetch("formulae")
  versions = VersionTracker.versions_for(package)

  puts if index.positive?
  puts "#{package_name}:"
  puts "  upstream: #{upstream.fetch("github")}"
  puts "  latest: #{versions.first || "none"}"
  puts "  matching_versions: #{versions.length}"
  puts "  primary_formula: #{formulae.fetch("primary")}"

  pinned = formulae.fetch("pinned", [])
  puts "  pinned_formulae: #{pinned.empty? ? "none" : pinned.join(", ")}"

  versions_to_print = options[:all] ? versions : versions.first(options[:limit])
  label = options[:all] ? "versions" : "recent_versions"
  puts "  #{label}:"
  versions_to_print.each { |version| puts "    - #{version}" }
end
