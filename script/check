#!/usr/bin/env bash
set -euo pipefail

cleanup() {
  rm -f steps_output.txt
}
trap cleanup EXIT

ruby -e 'require "yaml"; %w[config/tracked-packages.yml data/upstream-versions.yml].each { |path| YAML.load_file(path) if File.exist?(path) }'
ruby -c lib/version_tracker.rb
ruby -c script/tracked-versions
ruby -c script/update-version-catalog

if command -v pre-commit >/dev/null 2>&1; then
  pre-commit run --all-files
else
  echo "pre-commit is not installed; skipping pre-commit hooks"
fi

if command -v brew >/dev/null 2>&1; then
  brew test-bot --only-tap-syntax
else
  echo "brew is not installed; skipping Homebrew tap syntax check"
fi
