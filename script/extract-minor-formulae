#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "open3"
require "optparse"

require_relative "../lib/version_tracker"

options = {
  allow_missing: false,
  force: false,
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: script/extract-minor-formulae [options] [package ...]"

  opts.on("--force", "Overwrite existing versioned formulae") do
    options[:force] = true
  end

  opts.on("--allow-missing", "Continue when Homebrew/core does not contain a version") do
    options[:allow_missing] = true
  end
end

parser.parse!

def run_command(*command, allow_failure: false)
  output, status = Open3.capture2e(*command)
  puts output unless output.empty?
  return output if status.success?
  return nil if allow_failure

  abort "Command failed: #{command.join(" ")}"
end

def extract_formula(command, options)
  run_command(*command, allow_failure: options[:allow_missing])
end

def copy_formula(source, target, filename)
  abort "Expected extracted formula missing: #{source}" unless File.exist?(source)

  FileUtils.cp(source, target)
  puts "Wrote Formula/#{filename}"
end

def formula_filename(formula_name, version)
  "#{formula_name}@#{version}.rb"
end

def formula_target(workspace_formula_dir, filename)
  File.join(workspace_formula_dir, filename)
end

def formula_source(tap_formula_dir, filename)
  File.join(tap_formula_dir, filename)
end

def extract_command(formula_name, version, tap, force)
  command = ["brew", "extract", "--version=#{version}", formula_name, tap]
  command.insert(2, "--force") if force
  command
end

def record_missing(missing_versions, package_name, version)
  missing_versions << "#{package_name}@#{version}"
  warn "Missing in Homebrew/core history: #{package_name}@#{version}"
end

def print_missing(missing_versions)
  return if missing_versions.empty?

  warn "Missing formulae:"
  missing_versions.each { |formula| warn "  - #{formula}" }
end

def run_extract(package_name, formula_name, version, tap, options, tap_formula_dir, workspace_formula_dir, missing_versions)
  filename = formula_filename(formula_name, version)
  target = formula_target(workspace_formula_dir, filename)

  if File.exist?(target) && !options[:force]
    puts "Skipping existing #{filename}"
    return
  end

  command = extract_command(formula_name, version, tap, options[:force])
  output = extract_formula(command, options)

  if output.nil?
    record_missing(missing_versions, package_name, version)
    return
  end

  source = formula_source(tap_formula_dir, filename)
  copy_formula(source, target, filename)
end

def abort_if_missing(missing_versions, options)
  return if missing_versions.empty? || options[:allow_missing]

  print_missing(missing_versions)
  abort "Some formulae could not be extracted"
end

def warn_if_missing(missing_versions)
  print_missing(missing_versions)
end

def selected_versions(package_name, package)
  VersionTracker.minor_latest_versions_for(package_name, package)
end

def formula_name(package)
  package.fetch("formulae").fetch("primary")
end

def process_package(package_name, package, tap, options, tap_formula_dir, workspace_formula_dir, missing_versions)
  selected_versions(package_name, package).each do |version|
    run_extract(
      package_name,
      formula_name(package),
      version,
      tap,
      options,
      tap_formula_dir,
      workspace_formula_dir,
      missing_versions,
    )
  end
end

def process_packages(selected_packages, packages, tap, options, tap_formula_dir, workspace_formula_dir, missing_versions)
  selected_packages.each do |package_name|
    process_package(
      package_name,
      packages.fetch(package_name),
      tap,
      options,
      tap_formula_dir,
      workspace_formula_dir,
      missing_versions,
    )
  end
end

def finalize(missing_versions, options)
  warn_if_missing(missing_versions)
  abort_if_missing(missing_versions, options)
end

def extract_minor_formulae(selected_packages, packages, tap, options, tap_formula_dir, workspace_formula_dir)
  missing_versions = []
  process_packages(selected_packages, packages, tap, options, tap_formula_dir, workspace_formula_dir, missing_versions)
  finalize(missing_versions, options)
end

def tap_repo(tap)
  run_command("brew", "--repo", tap).strip
end

def workspace_formula_dir
  File.join(VersionTracker::ROOT, "Formula")
end

def tap_formula_dir(tap)
  File.join(tap_repo(tap), "Formula")
end

def ensure_formula_dir
  FileUtils.mkdir_p(workspace_formula_dir)
end

def run(options)
  packages = VersionTracker.packages
  selected_packages = VersionTracker.resolve_package_names(ARGV)
  tap = VersionTracker.load_config.fetch("tap")

  ensure_formula_dir
  extract_minor_formulae(selected_packages, packages, tap, options, tap_formula_dir(tap), workspace_formula_dir)
end

run(options)
